# ============================================================
# Trend Lens — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# ============================================================

# PostgreSQL connection string (asyncpg driver)
# Format: postgresql+asyncpg://user:password@host:port/database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/trendlens

# Redis connection string (used for API response caching)
REDIS_URL=redis://localhost:6379

# Reddit API credentials
# Get these from https://www.reddit.com/prefs/apps — create a "script" type app
REDDIT_CLIENT_ID=your_client_id
REDDIT_CLIENT_SECRET=your_client_secret
REDDIT_USER_AGENT=TrendLens/1.0 by YourUsername

# Application environment (development | production)
ENVIRONMENT=development

# CORS allowed origins (comma-separated for multiple origins)
CORS_ORIGINS=http://localhost:5173

# Cache TTL in seconds (default: 900 = 15 minutes)
CACHE_TTL_SECONDS=900

# How often to scrape sources, in minutes (default: 30)
SCRAPE_INTERVAL_MINUTES=30

# Number of topic clusters for KMeans (default: 8)
N_CLUSTERS=8
